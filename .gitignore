# Arch ISO + sigs + sumfile — manually downloaded into assets/ for staging
# onto the install USB (Rufus or `dd`). Not committed because they roll
# monthly and are large.
/assets/archlinux-x86_64.iso
/assets/archlinux-x86_64.iso.sig
/assets/archlinux-sha256sums.txt

# npm/pnpm
/node_modules/

# Editor/IDE — machine-specific paths leak in here (mise shims, etc.)
/.vscode/

# Temp working files
.tmp-*

# Edge headless crash/debug logs from `pnpm pdf`
/debug.log

# Generated PDFs — `pnpm pdf` re-renders from runbook/*.md.
/runbook/*.pdf
assets/Win11_25H2_English_x64_v2.iso
assets/ventoy-1.1.11*
