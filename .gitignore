# npm/pnpm
/node_modules/

# Editor/IDE — machine-specific paths leak in here (mise shims, etc.)
/.vscode/

# Claude Code worktrees (per-session sandboxes, not source)
/.claude/worktrees/

# Claude Code per-project memory — public repo, may contain identifiers
# safer kept local. Per ~/.claude/CLAUDE.md "Project memory" rule.
/.claude/memory/

# Temp working files
.tmp-*

# Edge headless crash/debug logs from `pnpm pdf`
/debug.log

# Generated PDFs — `pnpm pdf` re-renders from runbook/*.md.
/runbook/*.pdf
