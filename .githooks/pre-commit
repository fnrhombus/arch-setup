#!/usr/bin/env bash
# pre-commit hook — refuse to commit a Hyprland config with binding
# conflicts or unknown dispatchers. Runs validate-hypr-binds against
# the in-repo dotfiles tree (NOT against ~/.config/hypr/, since the
# committed change may not have been chezmoi-applied yet).
#
# Activate with:
#   git config core.hooksPath .githooks
# (run once per checkout — the .git directory's local config persists).
#
# Skip in emergencies with `git commit --no-verify` (sparingly!).

set -euo pipefail

# Only run if any hyprland config file is staged for commit.
if ! git diff --cached --name-only | grep -qE '^dotfiles/dot_config/hypr/.*\.conf$'; then
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
validator="$repo_root/dotfiles/dot_local/bin/executable_validate-hypr-binds"

if [[ ! -f "$validator" ]]; then
    echo "pre-commit: validate-hypr-binds not found at $validator (skipping)" >&2
    exit 0
fi

# Invoke via bash so the in-repo file doesn't need its +x bit — chezmoi's
# `executable_` prefix only sets exec bit on the APPLIED copy, not the
# source. (We do chmod +x it in-repo for direct invocations, but belt-
# and-braces.)
if ! HYPR_DIR="$repo_root/dotfiles/dot_config/hypr" bash "$validator"; then
    cat >&2 <<EOF

================================================================================
pre-commit: Hyprland binding conflicts in staged changes.
Fix the issues reported above, then re-stage and re-commit.
Bypass (NOT recommended) with:
    git commit --no-verify
================================================================================
EOF
    exit 1
fi
