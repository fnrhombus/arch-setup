#%PAM-1.0
# arch-setup: greetd PAM stack — PASSWORD ONLY at the greeter.
#
# Originally had pam_fprintd as `sufficient` ahead of system-login so a
# touch on the reader could log you in. In practice it hogged input —
# you couldn't type a password while pam_fprintd was waiting (up to
# max-tries × timeout seconds), and each timeout incremented
# pam_faillock until the account locked for 10 minutes. Removed.
#
# Fingerprint stays available at sudo + hyprlock (where input handling
# is different and the password prompt remains usable in parallel).
# At cold boot, just type the password.
#
# pam_gnome_keyring lines: auth + session + password are all needed.
#   - auth     optional  → passes the typed password to the keyring
#                          daemon via PAM_AUTHTOK so it can unlock
#                          ~/.local/share/keyrings/Default.keyring
#                          silently. WITHOUT this line the daemon
#                          starts (via session) but never gets the
#                          password, so apps prompt for it later.
#   - session  optional auto_start → starts gnome-keyring-daemon for
#                          the session.
#   - password optional → keeps the keyring password in sync if the
#                          user ever changes their UNIX password.
#
# Order constraint: `auth optional pam_gnome_keyring.so` must be AFTER
# `auth include system-login` so PAM_AUTHTOK is populated by the time
# pam_gnome_keyring reads it.
#
# Module name quirk: pinpam-git ships its module as libpinpam.so (not
# pam_pinpam.so). We do NOT include libpinpam at the greeter on purpose
# — PIN is not a greeter-tier auth method on this design.
#
# Installed to /etc/pam.d/greetd by phase-2-arch-install/chroot.sh AND
# re-stomped on every postinstall run by phase-3 §7a (drift correction).

auth        include     system-login
auth        optional    pam_gnome_keyring.so

account     include     system-login

password    include     system-login
password    optional    pam_gnome_keyring.so

session     include     system-login
session     optional    pam_gnome_keyring.so auto_start
