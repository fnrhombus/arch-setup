#!/bin/bash
# Replaces agetty on tty1: shows btop running as a non-privileged `lockuser`.
# Press q in btop to drop to the login prompt; if no login within 30s, btop
# resumes.
#
# Hardening:
#   - lockuser is a system user, no shell, in no useful groups (NOT in
#     `proc`). Kernel signal-perms refuse SIGKILL/etc to anything tom owns.
#   - /proc mounted hidepid=2,gid=proc means btop's process pane shows only
#     lockuser's own procs. Aggregate graphs (CPU/mem/swap/net/disk) still
#     render normally.

set -u

# Save current console font so a logged-in tom isn't stuck giant-mode.
PREV_FONT=$(mktemp -u /tmp/lockscreen-tty.font.XXXXXX)
setfont -O "$PREV_FONT" 2>/dev/null || PREV_FONT=
trap '[[ -n $PREV_FONT && -s $PREV_FONT ]] && setfont "$PREV_FONT" 2>/dev/null; [[ -n $PREV_FONT ]] && rm -f "$PREV_FONT"' EXIT

while true; do
    setfont ter-v32n 2>/dev/null || true
    runuser -u lockuser -- btop || true

    [[ -n $PREV_FONT && -s $PREV_FONT ]] && setfont "$PREV_FONT" 2>/dev/null

    # agetty exits non-zero on timeout → loop back to btop. On success it
    # execs login(1) which execs the user's shell; control returns here only
    # after that shell exits, then systemd's Restart=always respawns us.
    if /usr/bin/agetty --noclear --timeout=30 - linux; then
        break
    fi
done
