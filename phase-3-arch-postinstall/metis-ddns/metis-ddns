#!/bin/bash
# /usr/local/bin/metis-ddns — keep metis.rhombus.rocks A+AAAA in sync with
# this host's current public IPv4/IPv6 against Azure DNS.
#
# Read-only deps: curl, jq, /etc/metis-ddns.env (mode 600, user-supplied).
# Writes a value cache to /var/lib/metis-ddns/{a,aaaa}.last and a JWT cache
# to /run/metis-ddns-token.json so a no-op run is one ipify roundtrip per
# stack and zero Azure traffic.
#
# Exit non-zero only on hard failure (missing env file, all IP detection
# failed, or Azure 4xx). A network outage that drops both ipify probes is a
# soft failure: log + exit 0 so the timer doesn't spam journald.

set -euo pipefail

ENV_FILE="/etc/metis-ddns.env"
CACHE_DIR="/var/lib/metis-ddns"
TOKEN_CACHE="/run/metis-ddns-token.json"

log()  { printf 'metis-ddns: %s\n' "$*"; }
warn() { printf 'metis-ddns: WARN %s\n' "$*" >&2; }
die()  { printf 'metis-ddns: ERR %s\n' "$*" >&2; exit 1; }

[[ -r "$ENV_FILE" ]] || die "$ENV_FILE not readable — fill in service principal creds (template at /etc/metis-ddns.env.template)"
# shellcheck disable=SC1090
. "$ENV_FILE"

for v in AZ_TENANT_ID AZ_CLIENT_ID AZ_CLIENT_SECRET AZ_SUBSCRIPTION_ID AZ_RESOURCE_GROUP AZ_DNS_ZONE AZ_DNS_RECORD; do
    [[ -n "${!v:-}" ]] || die "$v is empty in $ENV_FILE"
done

mkdir -p "$CACHE_DIR"

# Detect public IPs. ipify's ipv4-only / ipv6-only hostnames force the
# stack we want; api.ipify.org is dual-stack and would return whichever
# curl picks. Each probe gets 10s — outage tolerance.
IPV4=$(curl -4 -fsS --max-time 10 https://api.ipify.org 2>/dev/null || true)
IPV6=$(curl -6 -fsS --max-time 10 https://api6.ipify.org 2>/dev/null || true)

if [[ -z "$IPV4" && -z "$IPV6" ]]; then
    warn "no public IP detected (both v4 and v6 probes failed) — network down? skipping."
    exit 0
fi

LAST_V4=$(cat "$CACHE_DIR/a.last" 2>/dev/null || true)
LAST_V6=$(cat "$CACHE_DIR/aaaa.last" 2>/dev/null || true)

# Short-circuit: nothing changed → no Azure call.
if [[ "$IPV4" == "$LAST_V4" && "$IPV6" == "$LAST_V6" ]]; then
    exit 0
fi

# JWT cache. Token is good ~1h; refresh if <60s remaining or cache absent.
TOKEN=""
if [[ -r "$TOKEN_CACHE" ]]; then
    EXP=$(jq -r '.expires_at // 0' "$TOKEN_CACHE" 2>/dev/null || echo 0)
    if (( EXP > $(date +%s) + 60 )); then
        TOKEN=$(jq -r '.access_token' "$TOKEN_CACHE")
    fi
fi

if [[ -z "$TOKEN" ]]; then
    log "minting new Azure access token..."
    RESP=$(curl -fsS --max-time 15 \
        -X POST "https://login.microsoftonline.com/${AZ_TENANT_ID}/oauth2/v2.0/token" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        --data-urlencode "grant_type=client_credentials" \
        --data-urlencode "client_id=${AZ_CLIENT_ID}" \
        --data-urlencode "client_secret=${AZ_CLIENT_SECRET}" \
        --data-urlencode "scope=https://management.azure.com/.default") \
        || die "token request failed"
    TOKEN=$(echo "$RESP" | jq -r '.access_token // empty')
    EXPIRES_IN=$(echo "$RESP" | jq -r '.expires_in // 3600')
    [[ -n "$TOKEN" ]] || die "token request returned empty access_token: $RESP"
    EXPIRES_AT=$(($(date +%s) + EXPIRES_IN))
    echo "$RESP" | jq ". + {\"expires_at\": $EXPIRES_AT}" > "$TOKEN_CACHE"
    chmod 600 "$TOKEN_CACHE"
fi

URL_BASE="https://management.azure.com/subscriptions/${AZ_SUBSCRIPTION_ID}/resourceGroups/${AZ_RESOURCE_GROUP}/providers/Microsoft.Network/dnsZones/${AZ_DNS_ZONE}"
API_VER="api-version=2018-05-01"
TTL="${AZ_DNS_TTL:-300}"

# PUT (CreateOrUpdate) — works whether the record exists or not, so first run
# creates metis.rhombus.rocks if the user hasn't pre-created it in Azure portal.
upsert() {
    local kind="$1" ip="$2" body
    if [[ "$kind" == "A" ]]; then
        body=$(jq -nc --arg ip "$ip" --argjson ttl "$TTL" \
            '{properties:{TTL:$ttl,ARecords:[{ipv4Address:$ip}]}}')
    else
        body=$(jq -nc --arg ip "$ip" --argjson ttl "$TTL" \
            '{properties:{TTL:$ttl,AAAARecords:[{ipv6Address:$ip}]}}')
    fi
    curl -fsS -X PUT \
        -H "Authorization: Bearer $TOKEN" \
        -H "Content-Type: application/json" \
        -d "$body" \
        "${URL_BASE}/${kind}/${AZ_DNS_RECORD}?${API_VER}" >/dev/null
}

if [[ -n "$IPV4" && "$IPV4" != "$LAST_V4" ]]; then
    upsert A "$IPV4" || die "Azure PUT A failed"
    echo "$IPV4" > "$CACHE_DIR/a.last"
    log "A    ${AZ_DNS_RECORD}.${AZ_DNS_ZONE} → $IPV4"
fi

if [[ -n "$IPV6" && "$IPV6" != "$LAST_V6" ]]; then
    upsert AAAA "$IPV6" || die "Azure PUT AAAA failed"
    echo "$IPV6" > "$CACHE_DIR/aaaa.last"
    log "AAAA ${AZ_DNS_RECORD}.${AZ_DNS_ZONE} → $IPV6"
fi
