{
  "name": "arch-setup",
  "private": true,
  "version": "0.0.0",
  "description": "Dual-boot Windows 11 + Arch Linux bootstrap for Dell Inspiron 7786. Planning docs, Windows unattend, Arch install/post-install scripts, and Ventoy USB artifacts.",
  "scripts": {
    "prepare": "node scripts/setup-hooks.mjs",
    "postinstall": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-assets.ps1",
    "restore": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-assets.ps1",
    "restore:force": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-assets.ps1 -Force",
    "stage": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/stage-ventoy.ps1 && pnpm prune:usb",
    "stage:force": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/stage-ventoy.ps1 -Force && pnpm prune:usb",
    "prune:usb": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/prune-usb.ps1",
    "pdf": "node scripts/runbook-pdf.mjs",
    "hash:win11": "node scripts/fetch-win11-hash.mjs",
    "hash:win11:update": "node scripts/fetch-win11-hash.mjs --update",
    "fetch:win11": "node scripts/fetch-win11-hash.mjs --download --update"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:fnrhombus/arch-setup.git"
  },
  "author": "fnrhombus",
  "license": "MIT",
  "devDependencies": {
    "marked": "^18.0.1",
    "playwright": "^1.48.0"
  }
}
