#!/usr/bin/env bash
# chezmoi pre-apply hook — refuse to apply a Hyprland config with
# binding conflicts or unknown dispatchers.
#
# Runs against the chezmoi *destination* state (i.e., what's about to be
# written), so we point the validator at chezmoi's source-state staging
# directory if we can; otherwise validate the existing config (so we're
# at least catching pre-existing conflicts before we make them worse).

set -euo pipefail

# If the validator hasn't been written yet (first apply), skip — nothing
# to validate against.
validator="$HOME/.local/bin/validate-hypr-binds"
if [[ ! -x "$validator" ]]; then
    echo "chezmoi pre-apply: validator not yet installed; skipping bind check on first apply"
    exit 0
fi

# Validate the destination state. On first install ~/.config/hypr/ may
# not exist yet — exit 0 in that case (nothing to break).
if [[ ! -f "$HOME/.config/hypr/hyprland.conf" ]]; then
    echo "chezmoi pre-apply: no hyprland.conf yet; skipping"
    exit 0
fi

if ! "$validator"; then
    cat >&2 <<EOF

================================================================================
chezmoi pre-apply: Hyprland binding conflicts detected.
Fix the duplicates / unknown dispatchers reported above, then re-run
'chezmoi apply'. Skip this check (NOT recommended) with:
    chezmoi apply --force
================================================================================
EOF
    exit 1
fi
