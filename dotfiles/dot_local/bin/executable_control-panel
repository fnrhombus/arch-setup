#!/usr/bin/env bash
# control-panel — fuzzel-launched menu of GUI settings tools.
# Bound to Super+, in binds.conf. Surfaces the obvious "where do I
# change X" entries so the user never has to memorize tool names.

set -euo pipefail

declare -A entries=(
    ["  Display"]="nwg-displays"
    ["  Wifi / Network"]="nm-connection-editor"
    ["  Bluetooth"]="overskride"
    ["  Sound"]="pwvucontrol"
    ["  Software (TUI)"]="ghostty -e pacseek"
    ["  Notifications panel"]="swaync-client -t -sw"
    ["  Theme: dark/light flip"]="$HOME/.local/bin/theme-toggle"
    ["  Wallpaper: rotate now"]="$HOME/.local/bin/wallpaper-rotate"
    ["  Resource monitor"]="missioncenter"
    ["  Color picker"]="hyprpicker -an"
    ["  Power menu"]="wleave"
    ["  Hibernate now"]="systemctl hibernate"
    ["  Lock screen"]="loginctl lock-session"
)

# Build menu in a stable order
ordered=(
    "  Display"
    "  Wifi / Network"
    "  Bluetooth"
    "  Sound"
    "  Software (TUI)"
    "  Notifications panel"
    "  Theme: dark/light flip"
    "  Wallpaper: rotate now"
    "  Resource monitor"
    "  Color picker"
    "  Power menu"
    "  Hibernate now"
    "  Lock screen"
)

choice=$(printf '%s\n' "${ordered[@]}" \
    | fuzzel --dmenu --width 36 --prompt 'control: ' --lines 13)

[[ -z "$choice" ]] && exit 0

cmd="${entries[$choice]}"
exec setsid -f sh -c "$cmd" >/dev/null 2>&1
