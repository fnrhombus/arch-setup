#!/usr/bin/env bash
# hypr-layout-tiling — force every window in the current workspace
# into the standard dwindle tiling layout. Bound to Super+Alt+T in
# binds.conf alongside the other layout-switch keys (Super+Alt+B
# tabbed, Super+Alt+F floating, [Super+Alt+S scrolling once
# hyprscroller is installed]).
set -euo pipefail
ws=$(hyprctl activeworkspace -j | jq -r '.id')
hyprctl clients -j | jq -r ".[] | select(.workspace.id == $ws) | .address" \
  | while IFS= read -r addr; do
        hyprctl dispatch settiled "address:$addr" >/dev/null
    done
hyprctl notify 5 1000 0 "Layout: tiling" 2>/dev/null || true
