#!/usr/bin/env bash
# tablet-mode-toggle — flip kbd/touchpad + on-screen-keyboard for the
# Inspiron 7786 2-in-1 when the lid folds back into tablet position.
#
# Wired three ways:
#   1. Automatic — udev rule (99-tablet-mode.rules) writes the SW_TABLET_MODE
#      value to /run/tablet-mode/state. A user-level systemd path unit
#      (tablet-mode-watch.path) notices the write and triggers
#      tablet-mode.service, which runs:
#          tablet-mode-toggle "$(cat /run/tablet-mode/state)"
#   2. Manual override — Hyprland keybind SUPER+ALT+K calls
#      `tablet-mode-toggle --toggle` (forces a flip regardless of sensor).
#   3. Detect — `tablet-mode-toggle --detect` sniffs sysfs for the current
#      SW_TABLET_MODE state and applies it (used at session start by the
#      `exec-once` line in execs.conf so a Hyprland restart resyncs).
#
# Args:
#   1            — entered tablet mode  (disable kbd+touchpad, launch OSK)
#   0            — entered laptop mode  (re-enable, kill OSK)
#   --toggle     — flip whichever state is cached
#   --detect     — read current state from /sys; apply
#
# Why the round-trip via /run/tablet-mode/state?
#   udev RUN+= runs as root with no Wayland/Hyprland env. Calling hyprctl
#   from there needs a wrapper that finds WAYLAND_DISPLAY +
#   HYPRLAND_INSTANCE_SIGNATURE and `runuser` into tom — fiddly and
#   fragile across logout/login. Bouncing through a user-level path unit
#   means the script always runs inside tom's session manager, which
#   already imported the Hyprland env at login (see execs.conf).
#
# Device-name caveat: the internal kbd shows up as `at-translated-set-2-keyboard`
# on most x86 laptops; the touchpad name is hardware-specific (`dell0896:00-04f3:30b6-touchpad`
# is the expected name on the 7786 per /proc/bus/input/devices but
# Hyprland canonicalises differently across libinput versions). Rather
# than hard-code, we query `hyprctl devices -j` at runtime and match by
# category — see disable_inputs() / enable_inputs() below.
#
# This script CAN be tested standalone with explicit args (`tablet-mode-toggle 1`
# then `tablet-mode-toggle 0`) without any sensor present — useful in WSL
# or before the udev rule lands.

set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/tablet-mode"
mkdir -p "$STATE_DIR"
STATE_FILE="$STATE_DIR/last-applied"

log() { printf '[tablet-mode] %s\n' "$*" >&2; }

notify() {
    local title="$1" body="$2"
    # hyprctl notify is the most reliable in-session toast (always present
    # when Hyprland is running). Fall back to notify-send if swaync is up.
    hyprctl notify -1 3000 "rgb(7aa2f7)" "$title — $body" >/dev/null 2>&1 \
        || notify-send -t 3000 "$title" "$body" 2>/dev/null \
        || true
}

# ---- Discover the actual Hyprland device names (kbd + touchpad) ----
# Returns one device name per line on stdout, prefixed with k=NAME or
# t=NAME. Empty output = Hyprland isn't running or no devices match.
discover_devices() {
    command -v hyprctl >/dev/null 2>&1 || return 0
    local json
    json=$(hyprctl devices -j 2>/dev/null) || return 0
    [[ -z "$json" ]] && return 0

    if command -v jq >/dev/null 2>&1; then
        # Internal kbd: name contains 'at-translated' (PS/2 protocol —
        # the only kbd that's actually internal; USB kbds plugged into a
        # docked tablet should keep working).
        echo "$json" | jq -r '.keyboards[]? | select(.name | test("at-translated"; "i")) | "k=" + .name'
        # Touchpads: any device whose name contains 'touchpad'. On the 7786
        # this is "dell0896:00-04f3:30b6-touchpad"; on other hw it varies.
        echo "$json" | jq -r '.mice[]? | select(.name | test("touchpad"; "i")) | "t=" + .name'
    else
        # jq absent — fall back to grep. hyprctl devices -j is a single
        # JSON blob with quoted "name" fields; this is brittle but works.
        echo "$json" \
            | grep -oE '"name": *"[^"]*at-translated[^"]*"' \
            | sed -E 's/.*"name": *"([^"]*)".*/k=\1/'
        echo "$json" \
            | grep -oE '"name": *"[^"]*touchpad[^"]*"' \
            | sed -E 's/.*"name": *"([^"]*)".*/t=\1/'
    fi
}

apply_device_state() {
    local enabled="$1"  # "true" or "false"
    local line kind name
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        kind="${line%%=*}"
        name="${line#*=}"
        if hyprctl keyword "device:${name}:enabled" "$enabled" >/dev/null 2>&1; then
            log "device $kind '$name' enabled=$enabled"
        else
            log "WARN: hyprctl keyword failed for device '$name' (enabled=$enabled)"
        fi
    done < <(discover_devices)
}

start_osk() {
    if pgrep -x wvkbd-mobintl >/dev/null 2>&1; then
        log "wvkbd-mobintl already running"
        return 0
    fi
    if ! command -v wvkbd-mobintl >/dev/null 2>&1; then
        log "wvkbd-mobintl not installed — skipping OSK"
        return 0
    fi
    # --hidden so the OSK starts collapsed; user swipes from screen edge
    # (or hyprgrass gesture) to summon. Daemonize via setsid so this
    # script can exit cleanly.
    setsid -f wvkbd-mobintl --hidden >/dev/null 2>&1 &
    log "wvkbd-mobintl launched (--hidden)"
}

stop_osk() {
    if pgrep -x wvkbd-mobintl >/dev/null 2>&1; then
        pkill -x wvkbd-mobintl 2>/dev/null || true
        log "wvkbd-mobintl killed"
    fi
}

enter_tablet() {
    log "→ entering tablet mode"
    apply_device_state false
    start_osk
    echo 1 > "$STATE_FILE"
    notify "Tablet mode" "Keyboard + touchpad disabled, OSK ready"
}

enter_laptop() {
    log "→ entering laptop mode"
    apply_device_state true
    stop_osk
    echo 0 > "$STATE_FILE"
    notify "Laptop mode" "Keyboard + touchpad re-enabled"
}

# ---- --detect: probe sysfs for the current SW_TABLET_MODE bit ----
# /sys/class/input/event*/device/capabilities/sw is a hex bitfield. Bit 1
# (0x2) corresponds to SW_TABLET_MODE. We then read the current state via
# evtest-equivalent: ioctl EVIOCGSW, exposed via the input device's
# `inhibited`/`device/state` is NOT a thing in mainline; the cleanest
# kernel-side surface is /sys/devices/.../input*/state. Since that
# requires the input device path which differs per boot, we keep this
# simple: any consumer wanting the live state reads /run/tablet-mode/state
# (last value the udev rule saw). Cold-boot fallback: assume laptop mode.
detect_state() {
    local current
    if [[ -r /run/tablet-mode/state ]]; then
        current=$(< /run/tablet-mode/state)
    elif [[ -r "$STATE_FILE" ]]; then
        current=$(< "$STATE_FILE")
    else
        current=0
    fi
    case "$current" in
        1) enter_tablet ;;
        0|"") enter_laptop ;;
        *) log "unknown state '$current' — assuming laptop"; enter_laptop ;;
    esac
}

case "${1:-}" in
    1)         enter_tablet ;;
    0)         enter_laptop ;;
    --toggle)
        last=0
        [[ -r "$STATE_FILE" ]] && last=$(< "$STATE_FILE")
        if [[ "$last" == "1" ]]; then enter_laptop; else enter_tablet; fi
        ;;
    --detect)  detect_state ;;
    *)
        cat >&2 <<EOF
Usage: tablet-mode-toggle <0|1>
       tablet-mode-toggle --toggle     # flip whichever state is cached
       tablet-mode-toggle --detect     # apply current sensor state
EOF
        exit 2
        ;;
esac
