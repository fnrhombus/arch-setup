#!/usr/bin/env bash
# hypr-cheatsheet — searchable GUI cheatsheet of every active Hyprland
# binding. Reads the live state via `hyprctl binds -j` and feeds the
# list through fuzzel's dmenu mode. Themed via matugen's fuzzel
# template, so it looks like the rest of the desktop.
#
# Bound to Super+/ in binds.conf.
#
# Format per row:  [Category] Description           MODS+KEY
# Sorted by category, then description, so related actions cluster
# (e.g., all "Open ..." quicklaunches together, all "Focus window ..."
# together) and you can fuzzel-search by what the binding *does*
# rather than memorizing the chord.
#
# Selecting an entry just dismisses; we don't auto-fire the action
# because dispatchers like `killactive` would do unexpected things to
# whatever was focused before fuzzel popped open.

set -euo pipefail

if ! command -v hyprctl >/dev/null; then
    notify-send -u critical "hypr-cheatsheet" "hyprctl not on PATH; are you in Hyprland?" 2>/dev/null
    exit 1
fi

mods_to_label() {
    case "$1" in
        0)   echo "" ;;
        1)   echo "Shift" ;;
        4)   echo "Ctrl" ;;
        5)   echo "Ctrl+Shift" ;;
        8)   echo "Alt" ;;
        9)   echo "Alt+Shift" ;;
        12)  echo "Ctrl+Alt" ;;
        13)  echo "Ctrl+Alt+Shift" ;;
        64)  echo "Super" ;;
        65)  echo "Super+Shift" ;;
        68)  echo "Super+Ctrl" ;;
        69)  echo "Super+Ctrl+Shift" ;;
        72)  echo "Super+Alt" ;;
        73)  echo "Super+Alt+Shift" ;;
        *)   echo "mod${1}" ;;
    esac
}

# Derive a category from the dispatcher + arg + key. Used to group
# related bindings in the cheatsheet output. Categories are short so
# the bracketed prefix doesn't crowd the description column.
categorize() {
    local dispatcher="$1" arg="$2" key="$3"
    case "$dispatcher" in
        killactive|togglefloating|togglesplit|togglegroup|fullscreen|pin)
            echo "Window" ;;
        movefocus)
            echo "Focus" ;;
        movewindow|movewindowpixel|moveactive)
            echo "Window" ;;
        resizewindow|resizeactive|resizewindowpixel)
            echo "Resize" ;;
        workspace|movetoworkspace|movetoworkspacesilent|togglespecialworkspace)
            echo "Workspace" ;;
        submap)
            echo "Mode" ;;
        exec)
            case "$arg" in
                *swayosd-client*|*playerctl*)        echo "Media" ;;
                *hyprshot*|*satty*)                  echo "Screenshot" ;;
                *systemctl*hibernate*|*loginctl*lock*|*wleave*) echo "Power" ;;
                *theme-toggle*|*wallpaper-rotate*)    echo "Theme" ;;
                *hyprctl*reload*|*hyprpicker*)        echo "Hyprland" ;;
                *hypr-cheatsheet*)                    echo "Help" ;;
                *control-panel*|*pkill*waybar*)       echo "System" ;;
                *cliphist*|*fuzzel*emoji*)            echo "Pickers" ;;
                *swaync-client*)                      echo "Notifications" ;;
                *)                                    echo "Apps" ;;
            esac ;;
        *)
            echo "Misc" ;;
    esac
}

format_bind() {
    local modmask="$1" key="$2" description="$3" dispatcher="$4" arg="$5"
    local label combo category rhs
    label=$(mods_to_label "$modmask")
    if [[ -z "$label" ]]; then combo="$key"
    else combo="${label}+${key}"; fi

    if [[ -n "$description" && "$description" != "null" ]]; then
        rhs="$description"
    elif [[ -z "$arg" || "$arg" == "null" ]]; then
        rhs="$dispatcher"
    else
        rhs="$dispatcher $arg"
    fi
    category=$(categorize "$dispatcher" "$arg" "$key")

    # Two-column layout: "[Cat] Description" then "MODS+KEY".
    # The leading category prefix means a `sort` puts everything in
    # the same group together, and within a group sorts by description
    # — which is what the user wants to scan against.
    printf '[%-13s] %-40s   %s\n' "$category" "$rhs" "$combo"
}

hyprctl binds -j 2>/dev/null \
  | jq -r '.[] | [.modmask, .key, (.description // ""), .dispatcher, (.arg // "")] | @tsv' \
  | while IFS=$'\t' read -r modmask key description dispatcher arg; do
        format_bind "$modmask" "$key" "$description" "$dispatcher" "$arg"
    done \
  | sort \
  | fuzzel --dmenu --width 100 --lines 35 --prompt "Hyprland binds: " >/dev/null
