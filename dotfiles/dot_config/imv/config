; imv — image viewer. Minimal config; defaults are good.

[options]
background = 1f1f1f
overlay_font = JetBrainsMono Nerd Font:14
overlay_position_bottom = true
overlay = false
scaling_mode = shrink
recursive = false
loop_input = true
slideshow_duration = 0
title_text = imv - [${imv_current_index}/${imv_file_count}] ${imv_current_file} [${imv_scale}%]

[binds]
q = quit
; Pan / zoom defaults are fine; we add vim-ish nav
h = prev
l = next
j = zoom -1
k = zoom 1
g = goto 1
G = goto -1
r = reset
o = open
