# Ghostty theme — STATIC VS Code Default Dark+ palette + matugen accents.
# Activated via `theme = matugen` in ~/.config/ghostty/config.
#
# Same theming philosophy as the other matugen templates: terminal
# background, foreground, and the 16-color ANSI palette are pinned
# (so `ls` colors stay consistent regardless of wallpaper); only the
# cursor and selection highlight are matugen-derived for a subtle
# wallpaper-tinted accent.
#
# 16-color palette taken from VS Code's default integrated terminal
# (matches the editor's color scheme so syntax highlighting and
# terminal output share the same palette).

palette = 0=#000000
palette = 1=#cd3131
palette = 2=#0dbc79
palette = 3=#e5e510
palette = 4=#2472c8
palette = 5=#bc3fbc
palette = 6=#11a8cd
palette = 7=#e5e5e5
palette = 8=#666666
palette = 9=#f14c4c
palette = 10=#23d18b
palette = 11=#f5f543
palette = 12=#3b8eea
palette = 13=#d670d6
palette = 14=#29b8db
palette = 15=#e5e5e5

# Static fills (VS Code Default Dark+)
background = #1e1e1e
foreground = #d4d4d4

# Matugen-derived accents — cursor + selection only.
cursor-color = {{colors.primary.default.hex}}
cursor-text = {{colors.on_primary.default.hex}}
selection-background = {{colors.primary_container.default.hex}}
selection-foreground = {{colors.on_primary_container.default.hex}}
